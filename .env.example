# BIOMATRIC environment template
# Copy to `.env` on the server before running `docker compose up`.
#
# IMPORTANT: BIOMATRIC now shares the DELIGHT MODEL SCHOOL Postgres database.
# Bring the DMS stack up first so the database + `school-net` network exist:
#   cd "../DELIGHT MODEL SCHOOL - CLAUDE" && docker compose up -d db backend

# Database credentials — must match the DMS stack so we connect to the same DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
POSTGRES_DB=delight_school

# How BIOMATRIC reaches the DB. `dms-db` is the container name in the DMS
# compose file. Override only if you ran the DMS stack with a different name.
DB_HOST=dms-db

# Schema where BIOMATRIC stores its own tables. Created by the DMS bootstrap
# (CREATE SCHEMA IF NOT EXISTS biomatric) — keep this as `biomatric` unless
# you renamed it on the DMS side.
BIOMATRIC_DB_SCHEMA=biomatric

# Admin/scanner token HMAC secret (required)
# Generate with: openssl rand -hex 32
ADMIN_TOKEN_SECRET=replace-with-64-hex-chars

# Default Delight Model School admin (optional)
# Leave DEFAULT_ADMIN_PASSWORD empty to skip auto-creating the admin row.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# CORS allowlist (comma-separated public UI URLs)
ALLOWED_ORIGINS=http://localhost:7200,https://your-domain.example

# Face engine tuning
FACE_MATCH_THRESHOLD=0.60
FACE_DUPLICATE_THRESHOLD=0.60
# off | basic | strict. Production recommendation: basic or strict.
LIVENESS_MODE=basic
APP_TIMEZONE=Asia/Kolkata

# Billing
PRICE_PER_USER_PER_DAY=3
DEFAULT_BILLING_DAYS=30
DEFAULT_FREE_ORG_NAME=Delight Model School
DEFAULT_FREE_ORG_SLUG=delight-model-school

# DMS integration. Because both stacks share the school-net network, the
# default URL points to the DMS backend by container name. Replace with the
# public URL only if you put DMS on a different host.
DMS_BASE_URL=http://dms-backend:8000/api/v1
DMS_WEBHOOK_SECRET=

# Logging
LOG_LEVEL=INFO
